{
  "step": 1,
  "artifact_type": "window_or_page",
  "id": "WIN:WIN_Inicio_LUCCA",
  "name": "WIN_Inicio_LUCCA",
  "module": "Shell/Inicio",
  "output_dir": "docs/as-is/windows/",
  "output_filename": "WIN_WIN_Inicio_LUCCA.json",
  "purpose": "Ventana principal (shell) del GRP en escritorio Windows. Inicializa branding (LUCCA vs SIATEC), valida versión, carga componentes embebidos (pendientes/agenda/etc.), gestiona side-menu masivo y navegación a módulos.",
  "entrypoints": [
    {
      "event": "Global declarations / MyWindow",
      "summary": "Si no hay sesión (gnUSUARIO=0) abre splash (OpenSister) y difiere preparación de menú; si ya hay usuario, ejecuta Prepara_Menu().",
      "evidence_excerpt": "\t\t\tPROCEDURE MyWindow()\n\t\t\tgnUlBoton is int=0\n\t\t\tgnUltimaPosScroll is int=0\n\t\t\tsVer is string=\"\"\n\t\t\tgsNomVent is string=\"\"\n\t\t\tIF gnUSUARIO=0 THEN\n\t\t\t\tgnVantanaActiva=1\t\n\t\t\t\t//OpenSister(WIN_SplashAdvo)\t\t\n\t\t\t\tOpenSister(WIN_SPLASH_AdvoICONG)\t\t\n\t\t\tELSE\n\t\t\t\tPrepara_Menu()\n\t\t\tEND"
    },
    {
      "event": "End of initialization",
      "summary": "Determina sistema (LUCCA/ICONG) consultando DatosGrales.NOMSISTEM; configura captions/statusbar; valida versión vs LUCCA417; actualiza DLL/ZIP en disco; aplica LockAppTimeout; carga IW_Pendientes; restaura notas.",
      "evidence_excerpt": "\t\t\tEvent(MsWheel,\"SCROLL_NoName1\",522)\n\t\t\tsDirIp is string=NetIPAddress()\n\t\t\tsNomWin is string=NetMachineName()\n\t\t\t//HReadSeek(DatosGrales,CODIGO,1,hIdentical)\n\t\t\tBuscaQry2 is Data Source\n\t\t\tIF HExecuteSQLQuery(BuscaQry2, MyConnectionLucca, hQueryWithoutCorrection + hNoBind,\"SELECT NOMSISTEM FROM DatosGrales Where Codigo=1 \") = False THEN\n\t\t\t\tError(\"HFSQL error: \" + HErrorInfo())\n\t\t\tEND\n\t\t\tHReadFirst(BuscaQry2)\n\t\t\tBuscaQry is Data Source\n\t\t\tIF BuscaQry2.NOMSISTEM=\"LUCCA\" OR BuscaQry2.NOMSISTEM=\"\" THEN\n\t\t\t\tgsSistema=\"LUCCA\"\n\t\t\t\tIF In64bitMode()=True THEN\n\t\t\t\t\tgsNombreSistema=\"LUCCA 64 bits Ver.\" + ExeInfo(exeVersion,\"LUCCA.EXE\")\n\t\t\t\t\tIF HExecuteSQLQuery(BuscaQry, MyConnectionLucca, hQueryWithoutCorrection + hNoBind,\"SELECT Codigo, Version FROM LUCCA417 Where Codigo=64 \") = False THEN\n\t\t\t\t\t\tError(\"HFSQL error: \" + HErrorInfo())\n\t\t\t\t\tEND\n\t\t\t\t\tHReadFirst(BuscaQry)\n\t\t\t\t\tLUCCA417.Codigo=BuscaQry.codigo\n\t\t\t\t\tLUCCA417.Version=BuscaQry.Version\n\t\t\t\t\t//\t\tHReadSeek(LUCCA417,Codigo,64,hIdentical)\n\t\t\t\tELSE\n\t\t\t\t\tgsNombreSistema=\"LUCCA 32 bits Ver.\" + ExeInfo(exeVersion,\"LUCCA.EXE\")\n\t\t\t\t\tIF HExecuteSQLQuery(BuscaQry, MyConnectionLucca, hQueryWithoutCorrection + hNoBind,\"SELECT Codigo, Version FROM LUCCA417 Where Codigo=32 \") = False THEN\n\t\t\t\t\t\tError(\"HFSQL error: \" + HErrorInfo())\n\t\t\t\t\tEND\n\t\t\t\t\tHReadFirst(BuscaQry)\n\t\t\t\t\tLUCCA417.Codigo=BuscaQry.codigo\n\t\t\t\t\tLUCCA417.Version=BuscaQry.Version\n\t\t\t//\t\tHReadSeek(LUCCA417,Codigo,32,hIdentical)\n\t\t\t\tEND\n\t\t\t\tSBC_3=\"LUCCA es Marca Registrada ®\"\n\t\t\t\tsVer=ExeInfo(exeVersion,\"LUCCA.EXE\")\n\t\t\tELSE\n\t\t\t\tgsSistema=\"ICONG\"\n\t\t\t\tIF In64bitMode()=True THEN\n\t\t\t\t\tgsNombreSistema=\"SIATEC 64 bits Ver.\" + ExeInfo(exeVersion,\"SIATEC.EXE\")\n\t\t\t\t\tIF HExecuteSQLQuery(BuscaQry, MyConnectionLucca, hQueryWithoutCorrection + hNoBind,\"SELECT Codigo, Version FROM LUCCA417 Where Codigo=64 \") = False THEN\n\t\t\t\t\t\tError(\"HFSQL error: \" + HErrorInfo())\n\t\t\t\t\tEND"
    }
  ],
