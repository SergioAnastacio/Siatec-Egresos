  "database": {
    "engine": "SQL Server",
    "schema": "dbo",
    "connector": "PCSOFT Native SQL Server (hNativeAccessSQLServer)",
    "connections": [
      {
        "name": "MyConnectionLucca",
        "role": "Primary operational DB (LUCCA)",
        "config_source": {
          "file": "C:\\SIATEC\\Winpier.CHV",
          "decrypt": { "fn": "Uncrypt", "key": "FckGW" },
          "parsing": "ExtractString(..., '<br>') -> Database/Server/User/Password"
        },
        "provider": "hNativeAccessSQLServer",
        "access": "hOReadWrite",
        "cursor_options": "hClientCursor",
        "extended_info": "WD Lock Timeout=0; WD Command Timeout=0; TrustServerCertificate=Yes;"
      },
      {
        "name": "MyConnectionSivec",
        "role": "Secondary DBs configured via ConfInter (conditional)",
        "provider": "hNativeAccessSQLServer",
        "access": "hOReadWrite",
        "cursor_options": "hClientCursor",
        "extended_info": "WD Lock Timeout=0; WD Command Timeout=0; TrustServerCertificate=Yes;",
        "notes": "Se inicializa solo si ConfInter.CONTRASENA/SERVIDOR/BASEDATOS no están vacíos."
      },
      {
        "name": "MyConnectionIniC",
        "role": "Config/Directory DB (sivecc) + lookup Estructura",
        "provider": "hNativeAccessSQLServer",
        "access": "hOReadWrite",
        "cursor_options": "hClientCursor",
        "extended_info": "WD Lock Timeout=0; WD Command Timeout=0; TrustServerCertificate=Yes;"
      },
      {
        "name": "MyConnectionContAnt",
        "role": "Contable (legacy/aux)",
        "status": "declared_only_in_package_1"
      },
      {
        "name": "MyConnectionContable",
        "role": "Contable (principal)",
        "status": "declared_only_in_package_1"
      }
    ],
    "connection_switching": {
      "default": "HChangeConnection('*', MyConnectionLucca)",
      "conditional_groups": [
        {
          "condition": "ConfInter.CONTRASENA/SERVIDOR/BASEDATOS definidos",
          "switch_targets": [
            "SIVEC001",
            "SIVEC001C",
            "SIVEC002",
            "SIVEC003",
            "SIVEC006",
            "SIVEC048",
            "SIVEC057",
            "SIVEC065"
          ],
          "connection": "MyConnectionSivec"
        },
        {
          "switch_targets": ["SIAM", "SISKO", "NOBA", "SIVEC0A11", "SIVEC030"],
          "connection": "MyConnectionIniC"
        }
      ]
    }
  },
  "startup_sequence": [
    {
      "step": 1,
      "action": "Load and decrypt connection settings from file",
      "details": [
        "If directory C:\\SIATEC exists, load C:\\SIATEC\\Winpier.CHV",
        "Decrypt with Uncrypt(key='FckGW')",
        "Extract DB params from '<br>' delimited string"
      ],
      "dependencies": [{ "type": "filesystem", "path": "C:\\SIATEC\\Winpier.CHV" }]
    },
    {
      "step": 2,
      "action": "Open primary connection (LUCCA) and set as default",
      "details": ["HOpenConnection(MyConnectionLucca)", "HChangeConnection('*', MyConnectionLucca)"],
      "failure_handling": "Error('Error al cambiar la Base de Datos del sistema administrativo: ' + HErrorInfo())"
    },
    {
      "step": 3,
      "action": "Read ConfInter (CODIGO=1) and optionally open SIVEC connection group",
      "details": [
        "HReadSeekFirst(ConfInter, CODIGO, 1)",
        "If ConfInter.CONTRASENA/SERVIDOR/BASEDATOS != '' then configure MyConnectionSivec and HOpenConnection",
        "HChangeConnection for multiple SIVEC* logical connections"
      ]
    },
    {
      "step": 4,
      "action": "Configure IniC connection group (sivecc) and load Estructura",
      "details": [
        "Configure MyConnectionIniC (Database='sivecc') with password gsContraseñaIciCont",
        "HChangeConnection for SIAM/SISKO/NOBA/SIVEC0A11/SIVEC030",
        "Query: SELECT A1.Estructura FROM SISKO A1 Where A1.Directorio = <sCadenaDir>",
        "Set gsEstruc and derived gsEstrucConA"
      ],
      "queries": [
        {
          "kind": "sql",
          "crud": "read",
          "connection": "MyConnectionIniC",
          "sql": "SELECT A1.Estructura FROM SISKO A1 Where A1.Directorio = '<sCadenaDir>'"
        }
      ]
    },
    {
      "step": 5,
      "action": "Load server date and set global date",
      "details": ["Query: Select GETDATE() as Fecha", "gdFechaGral = dtPuente.Date"],
      "queries": [
        {
          "kind": "sql",
          "crud": "read",
          "connection": "MyConnectionIniC",
          "sql": "Select GETDATE() as Fecha"
        }
      ]
    },
    {
      "step": 6,
      "action": "Disable audit",
      "details": ["dbgAuditStatus(AuditDisabled)"]
    }
  ],
