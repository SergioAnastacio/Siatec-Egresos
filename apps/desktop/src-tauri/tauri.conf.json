{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Siatec Egresos",
  "version": "0.0.0",
  "identifier": "com.siatec.egresos.desktop",
  "build": {
    "beforeDevCommand": "pnpm -C .. dev:frontend",
    "devUrl": "http://localhost:3100",
    "beforeBuildCommand": "pnpm -C .. build:frontend",
    "frontendDist": "../out"
  },
  "app": {
    "windows": [
      {
        "title": "Siatec Egresos",
        "width": 1100,
        "height": 720,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ]
  }
}
