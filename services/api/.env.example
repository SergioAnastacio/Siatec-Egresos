# API host and port
API_HOST=127.0.0.1
API_PORT=3001

# Logging (RUST_LOG/EnvFilter style)
# Examples:
# API_LOG_LEVEL=info
# API_LOG_LEVEL=debug
# API_LOG_LEVEL=siatec_egresos_api=debug,tower_http=info
API_LOG_LEVEL=info

# Dev auth (static Bearer token). If unset, auth is disabled.
# Example:
# API_DEV_TOKEN=super-secret-dev-token
API_DEV_TOKEN=

# SQL Server smoke
# Example:
# SQLSERVER_URL=server=tcp:localhost,1433;database=master;user=sa;password=YourStrong!Passw0rd;trustservercertificate=true;encrypt=true
SQLSERVER_URL=
